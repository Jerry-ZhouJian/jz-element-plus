{
  "name": "jz-element-plus",
  "version": "0.0.7",
  "type": "module",
  "keywords": [
    "vue",
    "element-plus",
    "jz",
    "jz-element-plus",
    "ui",
    "components"
  ],
  "main": "./dist/jz-element-plus.cjs.js",
  "module": "./dist/jz-element-plus.es.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/jz-element-plus.es.js",
      "require": "./dist/jz-element-plus.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vue-tsc --noEmit && vite build",
    "type:check": "vue-tsc --noEmit",
    "dev": "vite"
  },
  "peerDependencies": {
    "element-plus": "^2.8.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^5.0.5",
    "element-plus": "^2.8.5",
    "sass": "^1.77.8",
    "typescript": "^5.6.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.3.0",
    "vue": "^3.4.38",
    "vue-tsc": "^2.1.6"
  }
}
